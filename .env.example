# notebook_runner — required secrets
# Copy this file to .env and fill in the values.
# Never commit .env to git.

# Hostname or IP of the AMD GPU server
GPU_HOST=

# SSH username on the GPU server (must have Docker access)
GPU_USER=

# HuggingFace access token — required for gated model downloads
# Get yours at https://huggingface.co/settings/tokens
HF_TOKEN=
